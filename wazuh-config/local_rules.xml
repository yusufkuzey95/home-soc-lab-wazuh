<!-- Catches privilege escalation when someone is added to the sudo group with
     usermod. Wazuh's built-in rule 2961 only fires for gpasswd, so a
     usermod -aG sudo slips right past it. Example log line:
     usermod[6787]: add 'eviluser' to group 'sudo' -->
<group name="local,syslog,privilege_escalation,">

  <rule id="100002" level="10">
    <program_name>usermod</program_name>
    <match>to group 'sudo'</match>
    <description>User added to sudo group via usermod - possible privilege escalation.</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>privilege_escalation,account_manipulation,</group>
  </rule>

</group>
