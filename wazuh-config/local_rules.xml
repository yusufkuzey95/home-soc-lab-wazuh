<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<!-- Detection 3: catch privilege escalation via `usermod -aG sudo`, which the -->
<!-- built-in rule 2961 misses because it only decodes gpasswd, not usermod.  -->
<group name="local,syslog,privilege_escalation,">

  <!--
  Jul  4 19:37:39 host usermod[6787]: add 'eviluser' to group 'sudo'
  -->
  <rule id="100002" level="10">
    <program_name>usermod</program_name>
    <match>to group 'sudo'</match>
    <description>User added to sudo group via usermod - possible privilege escalation.</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>privilege_escalation,account_manipulation,</group>
  </rule>

</group>
